  - "\u0425\u043C\u2026\n\u041D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0439
    \u0433\u043E\u0441\u0442\u044C."
  - "\u042F \u0438 \u043D\u0435 \u0434\u0443\u043C\u0430\u043B\u0430, \u0447\u0442\u043E
    \u0432\u0441\u0442\u0440\u0435\u0447\u0443 \u0437\u0434\u0435\u0441\u044C \u043A\u043E\u0433\u043E-\u0442\u043E
    \u0441\u0442\u043E\u043B\u044C\u2026 \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E"
  - "\u041C\u0435\u043D\u044F \u0437\u043E\u0432\u0443\u0442 \u0414\u044D\u0441\u0438\u043D..."
  - "\u042F \u0436\u0438\u0432\u0443 \u0432 \u044D\u0442\u0438\u0445 \u0437\u0435\u043C\u043B\u044F\u0445
    \u0443\u0436\u0435 \u043E\u0447\u0435\u043D\u044C \u0434\u0430\u0432\u043D\u043E\u2026\n(\u043A\u0445\u0435-\u043A\u0445\u0435-\u043A\u0445\u0435\u2026)"
  - "\u0420\u0430\u0437 \u0443\u0436 \u0442\u044B \u0437\u0434\u0435\u0441\u044C
    \u2014 \u0437\u043D\u0430\u0447\u0438\u0442, \u043C\u0438\u0440 \u0443\u0436\u0435
    \u043D\u0430\u0447\u0430\u043B \u043D\u0430 \u0442\u0435\u0431\u044F \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u0432 \u043E\u0442\u0432\u0435\u0442.\n\u0418 \u043F\u043E\u0432\u0435\u0440\u044C,
    \u044D\u0442\u043E \u0440\u0435\u0434\u043A\u043E \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u043E\u0439."
  - "\u042D\u0442\u043E\u0442 \u043A\u0440\u0430\u0439\u2026\n\u0435\u0433\u043E
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u043F\u043E-\u0440\u0430\u0437\u043D\u043E\u043C\u0443.\n\u041A\u0442\u043E-\u0442\u043E
    \u2014 \u0437\u0435\u043C\u043B\u0451\u0439 \u0434\u0443\u0445\u043E\u0432,\n\u043A\u0442\u043E-\u0442\u043E
    \u2014 \u0437\u0430\u0431\u044B\u0442\u044B\u043C \u0446\u0430\u0440\u0441\u0442\u0432\u043E\u043C."
  - "\u041D\u043E \u0438\u0441\u0442\u0438\u043D\u0430 \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u0437\u0434\u0435\u0441\u044C\n\u0433\u0440\u0430\u043D\u0438\u0446\u044B
    \u043C\u0435\u0436\u0434\u0443 \u0436\u0438\u0432\u044B\u043C \u0438 \u043C\u0451\u0440\u0442\u0432\u044B\u043C\u2026\n\u043D\u0435
    \u0432\u0441\u0435\u0433\u0434\u0430 \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u043D\u0430 \u0441\u0432\u043E\u0438\u0445 \u043C\u0435\u0441\u0442\u0430\u0445."
  - "\u0422\u0435\u0431\u0435 \u043F\u043E\u0432\u0435\u0437\u043B\u043E, \u0447\u0442\u043E
    \u0442\u044B \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B \u043C\u0435\u043D\u044F.\n\u0418\u043B\u0438\u2026
    \u043D\u0435 \u043F\u043E\u0432\u0435\u0437\u043B\u043E. \u042D\u0442\u043E \u043C\u044B
    \u0435\u0449\u0451 \u0432\u044B\u044F\u0441\u043D\u0438\u043C."
  - "\u042F \u043F\u043E\u043C\u043E\u0433\u0443 \u0442\u0435\u0431\u0435 \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F.\n\u041D\u043E
    \u043D\u0435 \u0436\u0434\u0438, \u0447\u0442\u043E \u044D\u0442\u043E\u0442
    \u043C\u0438\u0440 \u0431\u0443\u0434\u0435\u0442 \u0441 \u0442\u043E\u0431\u043E\u0439
    \u0447\u0435\u0441\u0442\u0435\u043D."
  - "\u041F\u0440\u043E\u0439\u0434\u0438\u0441\u044C. \u041E\u0441\u043C\u043E\u0442\u0440\u0438\u0441\u044C.\n\u0417\u0434\u0435\u0441\u044C
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0435\u0441\u0442\u044C \u0447\u0442\u043E-\u0442\u043E,
    \u0447\u0442\u043E \u0438\u0449\u0435\u0442 \u0442\u0435\u0431\u044F \u0440\u0430\u043D\u044C\u0448\u0435,
    \u0447\u0435\u043C \u0442\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
    \u0435\u0433\u043E \u0441\u0430\u043C."
  - "\u041C\u043E\u0436\u0435\u0442, \u043D\u0430\u0439\u0434\u0451\u0448\u044C \u0447\u0442\u043E-\u0442\u043E
    \u043F\u043E\u043B\u0435\u0437\u043D\u043E\u0435\u2026\n(\u043A\u0445\u0435-\u043A\u0445\u0435-\u043A\u0445\u0435\u2026)\n\u2026\u0438\u043B\u0438
    \u0447\u0442\u043E-\u0442\u043E, \u0447\u0442\u043E \u043B\u0443\u0447\u0448\u0435
    \u0431\u044B\u043B\u043E \u0431\u044B \u043D\u0435 \u0442\u0440\u043E\u0433\u0430\u0442\u044C."
  dialogPanel: {fileID: 1379529378}
  dialogText: {fileID: 869373439}
  npcNameText: {fileID: 49342718}
  interactHint: {fileID: 1827453564}
  npcName: "\u0414\u0435\u0441\u0438\u043D"
  interactDistance: 2
  autoCloseDistance: 3.5
  typeSpeed: 0.03
